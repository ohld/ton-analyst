#!/usr/bin/env bash
# Install the `ton` CLI shipped with this skill.
# Uses uv (https://github.com/astral-sh/uv) to manage the Python env.
# - Creates a uv-managed venv at skills/ton-analyst/.venv
# - Installs locked deps from uv.lock
# - Writes a wrapper at ~/.local/bin/ton
#
# Usage:  ./setup              install / re-install
#         ./setup --uninstall  remove wrapper, keep venv
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$SKILL_DIR/.venv"
BIN="$HOME/.local/bin/ton"

if [ "${1:-}" = "--uninstall" ]; then
  if [ -e "$BIN" ] || [ -L "$BIN" ]; then
    rm -f "$BIN"
    echo "removed $BIN"
  fi
  echo "done (venv at $VENV left in place)."
  exit 0
fi

# Bootstrap uv if missing.
# Note: piping a remote shell script is a tradeoff — convenient for a dev-tool
# installer, but it's remote code execution. If you'd rather pre-install uv
# yourself (e.g. `brew install uv`), this script will detect it and skip the
# bootstrap.
if ! command -v uv >/dev/null 2>&1; then
  echo "==> uv not found; installing via the official script"
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="$HOME/.local/bin:$PATH"
fi

cd "$SKILL_DIR"
uv sync --frozen --no-dev

mkdir -p "$(dirname "$BIN")"
cat > "$BIN" <<EOF
#!/usr/bin/env bash
exec "$VENV/bin/python" "$SKILL_DIR/bin/ton" "\$@"
EOF
chmod +x "$BIN"

echo
echo "installed: $BIN -> $SKILL_DIR/bin/ton (venv: $VENV)"
echo
echo "Try:"
echo "  ton acc 0:CA1D9EDEEF40B3A9DBD9082F3767859547C3CE0BF641D09D58E33A3CF06FB309"
echo "  ton tx  0:CA1D9EDEEF40B3A9DBD9082F3767859547C3CE0BF641D09D58E33A3CF06FB309 --limit 10"
echo
echo "Optional env vars:"
echo "  TONAPI_API_KEY      bearer token for higher TONAPI rate limits"
echo "  TON_LABELS_CACHE    default ~/.cache/ton-labels"
echo
echo "Dev deps:  uv sync --group dev    # adds pytest + pytest-asyncio"
