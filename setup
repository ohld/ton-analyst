#!/usr/bin/env bash
set -euo pipefail

SKILL_NAME="ton-analyst"
REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_SRC="$REPO_DIR/skills/$SKILL_NAME"
SKILL_DST="$HOME/.claude/skills/$SKILL_NAME"
VENV_DIR="$SKILL_SRC/.venv"
REQ_FILE="$SKILL_SRC/requirements.txt"
CLI_SRC="$SKILL_SRC/bin/ton"
CLI_DST_DIR="$HOME/.local/bin"
CLI_DST="$CLI_DST_DIR/ton"

UNINSTALL=0
for arg in "$@"; do
  case "$arg" in
    --uninstall) UNINSTALL=1 ;;
    -h|--help)
      cat <<EOF
Usage: ./setup [--uninstall]

Installs the ton-analyst skill and the 'ton' CLI:
  - Creates a Python venv at skills/$SKILL_NAME/.venv
  - Installs requests + pytoniq-core pinned in requirements.txt
  - Symlinks skills/$SKILL_NAME -> ~/.claude/skills/$SKILL_NAME
  - Installs a small wrapper at ~/.local/bin/ton (uses the venv's python)

--uninstall removes the wrapper and skill symlink (venv is left in place).
EOF
      exit 0
      ;;
  esac
done

# ─── Uninstall path ──────────────────────────────────────────────
if [ "$UNINSTALL" = "1" ]; then
  echo "==> Uninstalling $SKILL_NAME"
  if [ -L "$CLI_DST" ] || [ -f "$CLI_DST" ]; then
    rm -f "$CLI_DST" && echo "    removed $CLI_DST"
  fi
  if [ -L "$SKILL_DST" ]; then
    rm -f "$SKILL_DST" && echo "    removed $SKILL_DST"
  fi
  echo "    (venv at $VENV_DIR left intact; rm -rf it if unwanted)"
  exit 0
fi

echo "==> Setting up $SKILL_NAME"

# 1. Validate skill source exists
if [ ! -f "$SKILL_SRC/SKILL.md" ]; then
  echo "ERROR: $SKILL_SRC/SKILL.md not found. Are you in the right repo?" >&2
  exit 1
fi

# 2. Python venv + requirements
if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 not found. Install Python 3.10+ first." >&2
  exit 1
fi

PY_VER="$(python3 -c 'import sys; print("%d.%d" % sys.version_info[:2])')"
case "$PY_VER" in
  3.10|3.11|3.12|3.13|3.14) ;;
  *)
    echo "WARNING: python3 is $PY_VER — ton-analyst targets Python 3.10+. Continuing." >&2
    ;;
esac

if [ ! -d "$VENV_DIR" ]; then
  echo "    creating venv at $VENV_DIR"
  python3 -m venv "$VENV_DIR"
else
  echo "    venv already exists at $VENV_DIR"
fi

echo "    installing dependencies from $REQ_FILE"
"$VENV_DIR/bin/pip" install --quiet --upgrade pip >/dev/null
"$VENV_DIR/bin/pip" install --quiet -r "$REQ_FILE"

# 3. Symlink the skill directory into ~/.claude/skills
mkdir -p "$HOME/.claude/skills"

if [ -L "$SKILL_DST" ]; then
  current_target="$(readlink "$SKILL_DST")"
  if [ "$current_target" = "$SKILL_SRC" ]; then
    echo "    skill symlink OK: $SKILL_DST -> $SKILL_SRC"
  else
    echo "    updating skill symlink: $current_target -> $SKILL_SRC"
    ln -sfn "$SKILL_SRC" "$SKILL_DST"
  fi
elif [ -e "$SKILL_DST" ]; then
  echo "WARNING: $SKILL_DST exists but is not a symlink. Skipping." >&2
else
  ln -s "$SKILL_SRC" "$SKILL_DST"
  echo "    created skill symlink: $SKILL_DST -> $SKILL_SRC"
fi

# 4. Install the `ton` CLI wrapper to ~/.local/bin
# We write a tiny wrapper (not a plain symlink to bin/ton) so the venv's
# python always runs the script. A raw symlink would fall back to system
# python, which may lack the deps we just installed.
mkdir -p "$CLI_DST_DIR"
cat >"$CLI_DST" <<EOF
#!/usr/bin/env bash
# ton-analyst CLI wrapper — auto-generated by setup, do not edit.
exec "$VENV_DIR/bin/python" "$CLI_SRC" "\$@"
EOF
chmod +x "$CLI_DST"
echo "    installed CLI wrapper: $CLI_DST"

# 5. PATH hint
case ":$PATH:" in
  *":$CLI_DST_DIR:"*) : ;;
  *)
    echo ""
    echo "    NOTE: $CLI_DST_DIR is not on your PATH. Add it:" >&2
    echo "      echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.zshrc" >&2
    ;;
esac

# 6. Env check
echo ""
echo "==> Checking environment (optional)"
if [ -n "${DUNE_API_KEY:-}" ]; then
  echo "    DUNE_API_KEY:            set"
else
  echo "    DUNE_API_KEY:            not set (only needed for Dune query exec)"
fi
if [ -n "${TONAPI_KEY:-}" ]; then
  echo "    TONAPI_KEY:              set"
else
  echo "    TONAPI_KEY:              not set (anon works; set for higher limits)"
fi
if [ -n "${TON_PROFILER_API_TOKEN:-}" ]; then
  echo "    TON_PROFILER_API_TOKEN:  set"
else
  echo "    TON_PROFILER_API_TOKEN:  not set (only needed for \`ton profile\`)"
fi

echo ""
echo "==> Done."
echo "    Try: ton addr 0:CA1D9EDEEF40B3A9DBD9082F3767859547C3CE0BF641D09D58E33A3CF06FB309"
echo "    ton-labels cache auto-clones on first \`ton label\` call."
